# ===========================================
# WHMCS AI Chatbot Configuration
# ===========================================

# ---------- Database ----------
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=secret
POSTGRES_DB=chatbot_db
POSTGRES_HOST=ai-chatbot-db
POSTGRES_PORT=5432

# ---------- Ollama (Local GPU Server) ----------
# Primary AI inference using local RTX 2080 Ti cluster
OLLAMA_HOST=96.31.83.171
OLLAMA_PORT=11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# ---------- Open-WebUI (Alternative UI) ----------
OPENWEBUI_HOST=96.31.83.171
OPENWEBUI_PORT=8080
OPENWEBUI_API_KEY=

# ---------- OpenRouter (Cloud Fallback) ----------
OPENROUTER_API_KEY=your-api-key
OPENROUTER_MODEL=google/gemma-3-27b-it
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# ---------- Qdrant Vector Database ----------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_KB=knowledge_base
QDRANT_COLLECTION_TICKETS=ticket_history
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# ---------- WHMCS API ----------
WHMCS_API_URL=https://your-whmcs.com/includes/api.php
WHMCS_API_KEY=your_api_secret
WHMCS_API_IDENTIFIER=your_api_identifier
WHMCS_USERNAME=admin_user
WHMCS_PASSWORD=admin_password
WHMCS_WEBHOOK_SECRET=your_webhook_secret

# ---------- n8n Workflow Automation ----------
N8N_HOST=n8n
N8N_PORT=5678
N8N_API_KEY=
N8N_WEBHOOK_URL=http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=changeme

# ---------- Redis (Caching & Rate Limiting) ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# ---------- Rate Limiting ----------
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ---------- Security ----------
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# ---------- PII Detection ----------
PII_DETECTION_ENABLED=true
PII_REDACTION_ENABLED=true

# ---------- Logging ----------
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true

# ---------- Timezone ----------
TZ=UTC
